{
  "name": "australia",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @au/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:logs": "docker compose -f infra/docker-compose.yml logs -f db",
    "db:psql": "docker compose -f infra/docker-compose.yml exec db psql -U au -d au",
    "db:migrate": "pnpm --filter @au/db migrate",
    "db:generate": "pnpm --filter @au/db generate",
    "db:seed": "pnpm --filter @au/db seed",
    "db:studio": "pnpm --filter @au/db studio",
    "ingest:federal": "pnpm --filter @au/ingest-federal start",
    "ingest:federal:boundaries": "pnpm --filter @au/ingest-federal boundaries",
    "ingest:vic": "pnpm --filter @au/ingest-state-vic start",
    "ingest:qld": "pnpm --filter @au/ingest-state-qld start",
    "ingest:act": "pnpm --filter @au/ingest-state-act start",
    "ingest:nsw": "pnpm --filter @au/ingest-state-nsw start"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}

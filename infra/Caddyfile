# If SITE_DOMAIN is set, serve HTTPS on that name (Caddy auto-issues a Let's
# Encrypt cert as soon as the A record points here). Always serve plain HTTP
# on the bare host so the IP-based URL keeps working.
{$SITE_DOMAIN} {
	encode zstd gzip
	reverse_proxy app:8080
}

:80 {
	encode zstd gzip
	reverse_proxy app:8080
}

# Postgres (matches infra/docker-compose.yml)
DATABASE_URL=postgres://au:au@localhost:5432/au

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Geocoding — pluggable; leave MAPBOX_TOKEN blank to use the Nominatim fallback
GEOCODER=nominatim
MAPBOX_TOKEN=

# Email transport — captured-mail in dev so nothing escapes
EMAIL_TRANSPORT=captured
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
EMAIL_FROM_ADDRESS=no-reply@democracy.au
EMAIL_REPLY_TO_VERIFIED_USER=true

# Cloudflare Turnstile (anti-bot on compose page)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Magic-link auth
AUTH_SECRET=change-me-to-a-long-random-string
